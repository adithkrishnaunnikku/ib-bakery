    <script>
    document.addEventListener("DOMContentLoaded", function () {

        const scrollContainer = document.getElementById('cake-scroll');
        const leftBtn = document.getElementById('scroll-left');
        const rightBtn = document.getElementById('scroll-right');

        if (!scrollContainer || !leftBtn || !rightBtn) return;

        let isHovered = false;

        const wrapper = document.createElement('div');
        wrapper.style.display = 'flex';
        wrapper.style.gap = '1.5rem';

        while (scrollContainer.firstChild) {
            wrapper.appendChild(scrollContainer.firstChild);
        }

        const clone = wrapper.cloneNode(true);

        scrollContainer.appendChild(wrapper);
        scrollContainer.appendChild(clone);

        let position = 0;
        let speed = 0.3;
		let baseSpeed = 0.3;
		let fastSpeed = 0.6;

        function autoScroll() {
            if (!isHovered) {
                position -= speed;

                if (Math.abs(position) >= wrapper.scrollWidth) {
                    position = 0;
                }

                /* ✅ FIXED */
                wrapper.style.transform = `translateX(${position}px)`;
                clone.style.transform = `translateX(${position}px)`;
            }

            requestAnimationFrame(autoScroll);
        }

		scrollContainer.addEventListener('mouseenter', () => {
			isHovered = true;
			speed = 0; // pause
		});

		scrollContainer.addEventListener('mouseleave', () => {
			isHovered = false;
			speed = baseSpeed; // resume slow
		});

		function smoothMove(target) {
			const duration = 400; // ms
			const start = position;
			const change = target - start;
			const startTime = performance.now();

			function animate(time) {
				const elapsed = time - startTime;
				const progress = Math.min(elapsed / duration, 1);

				// easeInOut
				const ease = progress < 0.5
					? 2 * progress * progress
					: 1 - Math.pow(-2 * progress + 2, 2) / 2;

				position = start + change * ease;

				if (progress < 1) {
					requestAnimationFrame(animate);
				}
			}

			requestAnimationFrame(animate);
		}
		
		leftBtn.addEventListener('click', () => {
			smoothMove(position + 300);
		});

		rightBtn.addEventListener('click', () => {
			smoothMove(position - 300);
		});

        autoScroll();
    });
    </script>
	
